# === STT ===
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# === TTS ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# === LLM ===
# For vLLM local inference, set the model path:
VLLM_MODEL_PATH=/models/mistral-7b-instruct-awq
# Optionally use OpenAI-compatible endpoint:
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# === SIP / Telephony ===
SIP_PROVIDER=twilio          # twilio | plivo
SIP_ACCOUNT_SID=your_twilio_account_sid
SIP_AUTH_TOKEN=your_twilio_auth_token
SIP_FROM_NUMBER=+1 978 355 7713

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=voice-ai-platform
